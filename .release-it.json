{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "github": {
    "release": true
  },
  "git": {
    "commitMessage": "chore: release ${version}"
  },
  "hooks": {
    "before:init": ["pnpm run build"]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
