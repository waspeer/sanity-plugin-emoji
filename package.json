{
  "name": "sanity-plugin-emoji",
  "version": "1.0.0",
  "description": "Emoji picker for Sanity Studio",
  "keywords": [
    "sanity",
    "sanity-plugin"
  ],
  "homepage": "https://github.com/waspeer/sanity-plugin-emoji#readme",
  "bugs": {
    "url": "https://github.com/waspeer/sanity-plugin-emoji/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/waspeer/sanity-plugin-emoji.git"
  },
  "license": "MIT",
  "author": "Wannes Salome <mail@wannessalome.nl>",
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "sanity.json",
    "src",
    "v2-incompatible.js"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.1.1",
    "@emoji-mart/react": "^1.1.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/incompatible-plugin": "^1.0.5",
    "@sanity/ui": "^3.0.7",
    "emoji-mart": "^5.6.0"
  },
  "devDependencies": {
    "@sanity/pkg-utils": "^8.1.0",
    "@sanity/plugin-kit": "^4.0.19",
    "@types/react": "^19.1.11",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sanity": "^4.6.0",
    "styled-components": "^6.1.19",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "sanity": "^3 || ^4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad"
}
